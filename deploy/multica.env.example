# Same-host production topology:
# Nginx -> npm run start -> same-origin frontend, API, and console proxy
# Keep VITE_API_BASE_URL unset in the frontend build for this mode.
NODE_ENV=production
PORT=5175
APP_ORIGIN=https://www.genericagent.example.com,https://genericagent.example.com
MULTICA_DATA_DIR=/data/multica/data
MULTICA_CONFIG_PATH=/data/multica/multica.config.json
# The deployment config should use archive mode and point at:
# /data/multica/templates/multica-template.tar.gz
MULTICA_TOKEN_SECRET=replace-with-a-long-random-token-secret
MULTICA_CONFIG_SECRET=replace-with-a-long-random-config-secret
MULTICA_DEPLOY_HOST=1.2.3.4
MULTICA_DEPLOY_PORT=22
MULTICA_DEPLOY_USERNAME=root
MULTICA_DEPLOY_ROOT_PASSWORD=replace-with-root-password
# Optional fixed instance router on the Multica instance host.
# Recommended production layout on 116:
# - prod router: http://10.128.0.4:19280 -> /data/multica/router/routes-prod
# - dev router:  http://34.71.182.116:19281 -> /data/multica/router/routes-dev
# When set, console URLs become ${MULTICA_ROUTER_BASE_URL}/instances/<instanceName>/
MULTICA_ROUTER_BASE_URL=http://10.128.0.4:19280
MULTICA_ROUTER_ROUTES_DIR=/data/multica/router/routes-prod
MULTICA_ROUTER_SHARED_TOKEN=replace-with-prod-router-shared-token
MULTICA_CONSOLE_PORT_BASE=58000
MULTICA_CONSOLE_PORT_RANGE=4000
MULTICA_MODEL_PROXY_BASE_URL=https://thousandengine.com
MULTICA_MODEL_PROXY_INTERNAL_BASE_URL=http://10.128.0.2:5175/api/internal/model-proxy
MULTICA_MODEL_PROXY_ALLOWED_REMOTE_ADDRESSES=10.128.0.4
MULTICA_MODEL_PROXY_MODEL_MAP_JSON={"gemini-3-1-pro":"gemini-3.1-pro-preview","gpt-5-4":"gpt-5.4","claude-opus-4-6":"claude-opus-4-6","glm-4-7":"glm-4.7","glm-5-1":"glm-5","gemini-3-pro":"gemini-3-pro-preview","gpt-4-1":"gpt-4.1"}
MULTICA_MODEL_PROXY_CHAT_MAX_TOKENS_CAP=1024
QS_KEY=replace-with-model-proxy-api-key
PAYMENT_PROVIDER=creem
CREEM_ENV=live
API_PROD_KEY=replace-with-creem-live-api-key
API_TEST_KEY=
CREEM_WEBHOOK_SECRET=
MULTICA_POSTGRES_HOST=127.0.0.1
MULTICA_POSTGRES_DB=multica_app
MULTICA_POSTGRES_USER=multica_app
MULTICA_POSTGRES_PASSWORD=replace-with-app-db-password
MULTICA_POSTGRES_PORT=5432
MULTICA_POSTGRES_ALLOWED_CIDR=0.0.0.0/0
PAY_CLIENT_ID=
PAY_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_ENV=
