# Duplicate this env per environment on the instance host, for example:
# - /data/multica-router/multica-instance-router-prod.env
# - /data/multica-router/multica-instance-router-dev.env
MULTICA_ROUTER_HOST=0.0.0.0
MULTICA_ROUTER_PORT=19280
MULTICA_ROUTER_ROUTES_DIR=/data/multica/router/routes-prod
MULTICA_ROUTER_SHARED_TOKEN=replace-with-a-long-random-internal-token
