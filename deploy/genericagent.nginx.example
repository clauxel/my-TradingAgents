# Replace the placeholder domains below with your final production hostnames before enabling this config.

server {
    listen 80;
    server_name www.genericagent.example.com genericagent.example.com;
    return 301 https://www.genericagent.example.com$request_uri;
}

server {
    listen 443 ssl http2;
    server_name www.genericagent.example.com;

    ssl_certificate /etc/letsencrypt/live/www.genericagent.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/www.genericagent.example.com/privkey.pem;

    client_max_body_size 10m;

    location / {
        proxy_pass http://127.0.0.1:5175;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}